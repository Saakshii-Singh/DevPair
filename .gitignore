# 1. Dependency Directories
# Ignored because these are downloaded fresh on npm install (huge files)
node_modules/
.pnpm-store/

# 2. Build and Distribution Outputs
# Ignored because these are generated automatically when building the project
dist/
build/
.tsbuildinfo

# 3. Environment Variables and Secrets
# CRITICAL: Ignored so you never leak private API keys (like Google Gemini API keys) to GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 4. Logs and Debugging Files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 5. IDE and Editor Settings
# System and editor configuration folders
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store